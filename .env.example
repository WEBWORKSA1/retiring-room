# RetiringRoom.com — environment variables
# Copy this file to .env.local and fill in real values once you have them.
# All PUBLIC_ variables are exposed to the client-side bundle.

# AdSense (apply at https://www.google.com/adsense after launch)
PUBLIC_ADSENSE_CLIENT=

# Affiliate IDs (sign up post-launch — leave blank for placeholder behaviour)
PUBLIC_AFF_MMT=
PUBLIC_AFF_OYO=
PUBLIC_AFF_REDBUS=
