---
const links = [
  { href: '/', label: 'Home' },
  { href: '/stations', label: 'Stations' },
  { href: '/cities', label: 'Cities' },
  { href: '/states', label: 'States' },
  { href: '/guides', label: 'Guides' },
];
const pathname = Astro.url.pathname;
---

<header class="border-b border-rail-ink/10 bg-rail-cream/80 backdrop-blur-md sticky top-0 z-50">
  <div class="container-rail flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2.5 no-underline group">
      <span class="w-8 h-8 bg-rail-ink rounded-sm flex items-center justify-center relative overflow-hidden">
        <span class="absolute inset-0 bg-rail-saffron" style="clip-path: polygon(0 100%, 100% 100%, 100% 60%);"></span>
        <span class="relative font-display font-bold text-rail-cream text-lg leading-none">R</span>
      </span>
      <span class="font-display font-semibold text-lg tracking-tight">
        retiring<span class="text-rail-saffron2">room</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {links.map((link) => {
        const active = pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
        return (
          <a
            href={link.href}
            class={`text-sm font-medium px-3 py-2 rounded-sm no-underline transition-colors ${
              active ? 'text-rail-saffron2 bg-rail-saffron/10' : 'text-rail-steel hover:text-rail-ink'
            }`}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <a href="https://www.rr.irctc.co.in/" target="_blank" rel="noopener" class="hidden sm:inline-flex items-center gap-1.5 text-xs font-medium text-rail-steel hover:text-rail-ink no-underline">
      <span class="live-dot inline-block w-1.5 h-1.5 rounded-full bg-rail-jade"></span>
      Book on IRCTC →
    </a>
  </div>
</header>
